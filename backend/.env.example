# Backend Environment Configuration
# Copy this file to .env and update values for your environment

# Database - PostgreSQL with asyncpg (required for production)
DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/db?sslmode=require

# For local development, you can use SQLite:
# DATABASE_URL=sqlite+aiosqlite:///./ojas.db

# Security Keys - Generate secure random values for production
# SECRET_KEY=openssl rand -hex 32
# ENCRYPTION_KEY=openssl rand -hex 16
SECRET_KEY=your-secure-secret-key-here
ENCRYPTION_KEY=your-secure-encryption-key-here
ENCRYPTION_SALT=ojas-salt-2026

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173

# Environment: development or production
ENVIRONMENT=development

# Rate limiting
RATE_LIMIT=100/minute

# Database connection pool settings
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=0

# WhatsApp Business API (360dialog)
# Get your key from https://www.360dialog.com/
WHATSAPP_API_KEY=
WHATSAPP_API_URL=https://waba.360dialog.io/v1/messages
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# Email service (Resend)
RESEND_API_KEY=

# Redis for caching (optional but recommended)
REDIS_URL=redis://localhost:6379

# Error tracking (Sentry)
SENTRY_DSN=

# Data Protection Officer contact (DPDPA compliance)
DPO_EMAIL=dpo@ojas.care

# Reset key - ONLY for local development, NEVER in production
RESET_KEY=only-for-local-dev-never-in-production
